  </div>

  <div class="annotations">
    <div class="ann-title">模块说明</div>
    <div class="legend">
      <div class="leg-item"><div class="leg-dot leg-ab"></div>A/B 测试区</div>
      <div class="leg-item"><div class="leg-dot leg-sh"></div>共用模块</div>
      <div class="leg-item"><div class="leg-dot leg-fx"></div>固定模块</div>
