<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>9MAX 高转化落地页结构图</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f5;padding:24px;color:#1a1a1a}
.canvas{display:flex;gap:24px;align-items:flex-start;max-width:960px;margin:0 auto}
.phone-wrap{flex-shrink:0;width:220px}
.phone-wrap-title{font-size:10px;font-weight:500;color:#888;text-align:center;margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em}
.phone{border:2px solid #333;border-radius:28px;overflow:hidden;background:#fff;position:relative}
.phone-notch{height:20px;background:#1a1a1a;display:flex;align-items:center;justify-content:center}
.phone-notch-dot{width:48px;height:5px;background:#333;border-radius:3px}
.phone-bottom{height:14px;background:#1a1a1a;display:flex;align-items:center;justify-content:center}
.phone-bar{width:60px;height:3px;background:#444;border-radius:2px}
.screen{background:#f5f5f5}
.zone{width:100%;position:relative}
.zone-label{font-size:9px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;padding:2px 6px;border-radius:3px;position:absolute;top:4px;right:4px;z-index:2}
.lbl-ab{background:#FAC775;color:#633806}
.lbl-shared{background:#9FE1CB;color:#085041}
.lbl-fixed{background:#D3D1C7;color:#444441}
.s-nav{background:#1a1a1a;padding:8px 10px;display:flex;align-items:center;justify-content:space-between;position:relative}
.s-nav .logo{font-size:11px;font-weight:500;color:#fff;letter-spacing:.04em}
.s-nav .partner-logos{display:flex;gap:3px}
.s-nav .plogo{width:14px;height:8px;background:#333;border-radius:1px}
.s-nav .cs-btn{font-size:9px;background:#25D366;color:#fff;padding:2px 6px;border-radius:3px}
.s-hero{position:relative;background:#2d4a1e;padding:12px 10px 10px;display:flex;flex-direction:column;align-items:center;gap:0}
.hero-img-ab{width:140px;height:80px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:500;margin-bottom:6px}
.hero-a{background:#3a5c26;color:#a8d87a;border:1px dashed #639922;flex-direction:column;gap:3px}
.hero-b{background:#4a2d1e;color:#f0997b;border:1px dashed #D85A30;flex-direction:column;gap:3px}
.hero-animals{display:flex;gap:6px}
.animal{width:32px;height:32px;background:#4a6e2e;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:14px}
.hero-person{width:56px;height:56px;background:#6b3a24;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px}
.s-hook{position:relative;background:#1e3510;padding:8px 10px}
.hook-ab-a{border-left:2px solid #639922}
.hook-ab-b{border-left:2px solid #D85A30}
.hook-title{font-size:13px;font-weight:500;color:#fff;line-height:1.2}
.hook-title span{color:#FFD700}
.hook-sub{font-size:9px;color:#8db86a;margin-top:2px}
.s-cta{background:#1a1a1a;padding:8px 10px;position:relative}
.cta-btn{width:100%;padding:9px 0;background:#fff;border-radius:8px;text-align:center;font-size:12px;font-weight:500;color:#1a1a1a;position:relative}
.cta-badge{position:absolute;top:-6px;right:8px;background:#E24B4A;color:#fff;font-size:8px;padding:1px 6px;border-radius:10px}
.cta-sub{font-size:8px;color:#888;text-align:center;margin-top:4px}
.s-trust{background:#f8f8f8;border-top:1px solid #eee;border-bottom:1px solid #eee;padding:7px 10px;display:flex;align-items:center;justify-content:space-between;position:relative}
.trust-rating{display:flex;align-items:center;gap:3px}
.trust-stars{display:flex;gap:1px}
.star{width:8px;height:8px;background:#EF9F27;clip-path:polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%)}
.trust-num{font-size:9px;color:#444;font-weight:500}
.trust-cert{font-size:8px;color:#3B6D11;background:#EAF3DE;padding:2px 5px;border-radius:3px}
.trust-users{font-size:8px;color:#888}
.s-payment{background:#fff;padding:7px 10px;position:relative}
.pay-title{font-size:8px;color:#888;margin-bottom:5px;font-weight:500;text-transform:uppercase;letter-spacing:.04em}
.pay-logos{display:flex;gap:5px;align-items:center}
.pay-logo{height:18px;border-radius:3px;border:1px solid #e5e5e5;padding:2px 6px;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:500}
.pl-oxxo{background:#e8151b;color:#fff;border-color:#e8151b}
.pl-clabe{background:#fff;color:#333;border-color:#ccc}
.pl-pc{background:#0066cc;color:#fff;border-color:#0066cc}
.pl-bank{background:#fff;color:#666;border-color:#ddd}
.pay-promise{font-size:8px;color:#3B6D11;margin-top:5px;display:flex;align-items:center;gap:3px}
.check{width:8px;height:8px;background:#3B6D11;border-radius:50%;display:inline-flex;align-items:center;justify-content:center}
.check::after{content:'';width:4px;height:2px;border-bottom:1.5px solid #fff;border-left:1.5px solid #fff;transform:rotate(-45deg) translate(0px,-1px);display:block}
.s-benefits{background:#1e3510;padding:8px 10px;position:relative}
.benefit-item{display:flex;align-items:flex-start;gap:5px;padding:3px 0;border-bottom:1px solid #2a4a1a}
.benefit-item:last-child{border-bottom:none}
.benefit-num{font-size:8px;color:#8db86a;min-width:12px;margin-top:1px}
.benefit-text{font-size:9px;color:#d4e8c0;line-height:1.4}
.benefit-text span{color:#FFD700;font-weight:500}
.s-games{background:#fff;padding:8px 10px;position:relative}
.game-cat-title{font-size:9px;font-weight:500;color:#444;margin-bottom:5px;padding-bottom:3px;border-bottom:1px solid #eee}
.game-row{display:flex;gap:4px;margin-bottom:7px}
.game-thumb{width:36px;height:28px;border-radius:4px;background:#e8e8e8;position:relative;overflow:hidden}
.game-thumb:nth-child(1){background:#c44b2a}
.game-thumb:nth-child(2){background:#2a5c9e}
.game-thumb:nth-child(3){background:#2a7a3e}
.game-thumb:nth-child(4){background:#8b3ea0}
.game-thumb:nth-child(5){background:#c4892a}
.game-hot{position:absolute;top:1px;left:1px;background:#E24B4A;color:#fff;font-size:6px;padding:0 2px;border-radius:1px}
.s-cs{background:#1a1a1a;padding:7px 10px;position:relative;display:flex;align-items:center;justify-content:space-between}
.cs-text{font-size:9px;color:#aaa;line-height:1.4}
.cs-text strong{color:#fff;display:block;font-size:10px;margin-bottom:1px}
.cs-wa{background:#25D366;color:#fff;font-size:9px;padding:5px 8px;border-radius:5px}
.s-sticky{background:#111;padding:6px 10px;display:flex;align-items:center;gap:8px;border-top:1px solid #333;position:relative}
.sticky-logo{font-size:9px;font-weight:500;color:#fff}
.sticky-claim{font-size:8px;color:#8db86a;flex:1}
.sticky-cta{background:#fff;color:#111;font-size:9px;font-weight:500;padding:5px 10px;border-radius:5px;white-space:nowrap}
.ver-toggle{display:flex;gap:6px;margin-top:10px;justify-content:center;flex-wrap:wrap}
.ver-btn{font-size:11px;padding:4px 10px;border-radius:5px;border:1px solid #ccc;background:#f0f0f0;color:#555;cursor:pointer}
.ver-btn.active{background:#fff;color:#1a1a1a;border-color:#999;font-weight:500}
.annotations{flex:1;min-width:0}
.ann-title{font-size:11px;font-weight:500;color:#888;text-transform:uppercase;letter-spacing:.05em;margin-bottom:12px}
.legend{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}
.leg-item{display:flex;align-items:center;gap:5px;font-size:11px;color:#666}
.leg-dot{width:10px;height:10px;border-radius:2px}
.leg-ab{background:#FAC775}
.leg-sh{background:#9FE1CB}
.leg-fx{background:#D3D1C7}
.ann{display:flex;gap:10px;margin-bottom:10px;align-items:flex-start}
.ann-num{font-size:13px;font-weight:500;min-width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.ann-num-ab{background:#FAEEDA;color:#633806}
.ann-num-sh{background:#E1F5EE;color:#085041}
.ann-num-fx{background:#F1EFE8;color:#444441}
.ann-body{flex:1}
.ann-label{font-size:13px;font-weight:500;color:#1a1a1a;margin-bottom:2px}
.ann-desc{font-size:11px;color:#666;line-height:1.55}
.tag-pill{display:inline-block;font-size:10px;padding:1px 7px;border-radius:10px;margin-left:4px;font-weight:500;vertical-align:middle}
.tp-ab{background:#FAC775;color:#633806}
.tp-sh{background:#9FE1CB;color:#085041}
.tp-fx{background:#D3D1C7;color:#444441}
.divider-line{border:none;border-top:1px solid #e5e5e5;margin:14px 0}
.copy-block{background:#f8f8f8;border-radius:8px;border:1px solid #e5e5e5;padding:10px 12px;margin-bottom:8px}
.copy-block-title{font-size:11px;font-weight:500;color:#888;margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em}
.copy-option{font-size:12px;color:#1a1a1a;padding:5px 0;border-bottom:1px solid #eee;line-height:1.4}
.copy-option:last-child{border-bottom:none}
.copy-option em{font-style:normal;font-weight:500}
.copy-sub{font-size:11px;color:#888;margin-top:1px}
</style>
</head>
<body>
<div class="canvas">
  <div class="phone-wrap">
    <div class="phone-wrap-title">落地页结构图</div>
    <div class="phone">
      <div class="phone-notch"><div class="phone-notch-dot"></div></div>
      <div class="screen">
        <div class="zone s-nav">
          <span class="zone-label lbl-fixed">固定</span>
          <span class="logo">9MAX</span>
          <div class="partner-logos">
            <div class="plogo"></div><div class="plogo"></div><div class="plogo"></div><div class="plogo"></div><div class="plogo"></div>
          </div>
          <span class="cs-btn">客服</span>
        </div>
        <div class="zone s-hero">
          <span class="zone-label lbl-ab">A/B</span>
          <div class="hero-img-ab hero-a" id="hero-a-vis">
            <div style="font-size:9px;color:#8db86a;font-weight:500">版本 A — 游戏角色</div>
