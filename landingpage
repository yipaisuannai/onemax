      <div class="phone-bottom"><div class="phone-bar"></div></div>
    </div>
    <div class="ver-toggle">
      <button class="ver-btn active" id="btn-reg" onclick="setVersion('reg')">注册钩子</button>
      <button class="ver-btn" id="btn-dep" onclick="setVersion('dep')">首充钩子</button>
      <button class="ver-btn" id="btn-plat" onclick="setVersion('plat')">平台噱头</button>
